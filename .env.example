# Mordecai's Maximus — Environment

# Optional fallback — or configure in app via ⚙️ Settings (same as Cloud Agents)
# CURSOR_API_KEY=your-cursor-api-key
# CURSOR_COMMISSION_REPO=owner/repo

# GitHub token (classic PAT or fine-grained with repo + pull_requests read) for PR review alerts
GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# Optional: restrict GitHub PR polling to specific repos (comma-separated "owner/repo")
# GITHUB_REPOS=yourname/your-repo,yourname/other-repo

# Optional: secret for desktop bridge webhook and task queue (required if set)
# MORDECAI_BRIDGE_SECRET=your-random-secret

# Required in production for privileged API writes (e.g. /api/config/agents)
# MORDECAI_ADMIN_TOKEN=your-admin-token

# Optional: FCM webhook URL to push to Flutter app (e.g. Firebase function sendAgentCompletedPush)
# MORDECAI_FCM_WEBHOOK=https://us-central1-PROJECT.cloudfunctions.net/sendAgentCompletedPush
# Optional: shared secret header required by the Firebase function
# MORDECAI_FCM_WEBHOOK_SECRET=your-fcm-webhook-secret

# Optional: dedicated ingest token for social webhook/event intake (Phase 1 automation).
# If set, clients must pass it as X-Phase1-Ingest-Token on /api/phase1/events.
# If unset, /api/phase1/events falls back to X-Bridge-Secret auth.
# MORDECAI_PHASE1_INGEST_TOKEN=your-phase1-ingest-token

# Phase 1 social auto-reply connectors (optional, based on your platforms):
# Meta/Facebook/Messenger direct Graph API mode:
# MORDECAI_META_PAGE_ACCESS_TOKEN=EAAB...
# MORDECAI_META_PAGE_ID=1234567890
# Meta fallback webhook mode (if you run your own relay):
# MORDECAI_META_REPLY_WEBHOOK=https://your-relay.example.com/meta/reply
#
# TikTok reply relay webhook (recommended for now):
# MORDECAI_TIKTOK_REPLY_WEBHOOK=https://your-relay.example.com/tiktok/reply
#
# YouTube comment reply API mode:
# MORDECAI_YOUTUBE_ACCESS_TOKEN=ya29...
# YouTube fallback webhook mode:
# MORDECAI_YOUTUBE_REPLY_WEBHOOK=https://your-relay.example.com/youtube/reply
#
# Catch-all fallback for unsupported platform labels:
# MORDECAI_SOCIAL_REPLY_WEBHOOK=https://your-relay.example.com/social/reply

# Optional: comma-separated origin allowlist for browser requests
# CORS_ALLOW_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# Optional: public URL for CORS/deep links when using Cloudflare Tunnel.
# Also passed to Flutter as MORDECAI_BASE_URL via cursor_mobile/run_with_repo_env.ps1
# MORDECAI_PUBLIC_URL=https://your-tunnel.trycloudflare.com

# Server port (default 3000)
PORT=3000

# Commission workspaces on disk (Cursor / local dev). Use an absolute path to put projects on D: etc.
# Default: <this repo>/commissions
# Windows example:
# COMMISSIONS_WORKSPACE=D:\MordecaiCommissions
# COMMISSIONS_WORKSPACE=./commissions

# Home Assistant bridge for Capabilities → Smart lights / thermostat (optional)
# Mordecai URL from your phone must reach this server; server must reach HA (LAN or Nabu Casa).
# MORDECAI_HOME_ASSISTANT_URL=http://homeassistant.local:8123
# Create a Long-Lived Access Token in HA profile, then:
# MORDECAI_HOME_ASSISTANT_TOKEN=your-long-lived-token
# Default entities (app can override via Configure → entity field = folder path in UI)
# MORDECAI_HOME_ASSISTANT_LIGHT_ENTITY=light.your_light
# MORDECAI_HOME_ASSISTANT_CLIMATE_ENTITY=climate.your_thermostat
# Optional shared secret — must match API key in app Configure for this capability
# MORDECAI_SMARTHOME_WEBHOOK_SECRET=random-string

# Alexa-only smart lights (no Home Assistant): Voice Monkey / IFTTT “trigger” URLs per action.
# Create Alexa routines that control your bulbs, then one Voice Monkey “monkey” (or IFTTT action) per routine.
# Paste each trigger URL below. App webhook: https://YOUR_ORIGIN/api/capabilities/alexa-lights
# MORDECAI_ALEXA_LIGHTS_ON_URL=https://...
# MORDECAI_ALEXA_LIGHTS_OFF_URL=https://...
# MORDECAI_ALEXA_LIGHTS_DIM50_URL=https://...
# MORDECAI_ALEXA_LIGHTS_DIM100_URL=https://...
# MORDECAI_ALEXA_TRIGGER_METHOD=GET

# Optional limits
# API_BODY_LIMIT=512kb
# API_RATE_LIMIT_PER_MIN=90
# POLL_RATE_LIMIT_PER_MIN=180
