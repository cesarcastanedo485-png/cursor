# Mordecai's Maximus — Environment

# Optional fallback — or configure in app via ⚙️ Settings (same as Cloud Agents)
# CURSOR_API_KEY=your-cursor-api-key
# CURSOR_COMMISSION_REPO=owner/repo

# GitHub token (classic PAT or fine-grained with repo + pull_requests read) for PR review alerts
GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# Optional: restrict GitHub PR polling to specific repos (comma-separated "owner/repo")
# GITHUB_REPOS=yourname/your-repo,yourname/other-repo

# Optional: secret for desktop bridge webhook and task queue (required if set)
# MORDECAI_BRIDGE_SECRET=your-random-secret

# Required in production for privileged API writes (e.g. /api/config/agents)
# MORDECAI_ADMIN_TOKEN=your-admin-token

# Optional: FCM webhook URL to push to Flutter app (e.g. Firebase function sendAgentCompletedPush)
# MORDECAI_FCM_WEBHOOK=https://us-central1-PROJECT.cloudfunctions.net/sendAgentCompletedPush
# Optional: shared secret header required by the Firebase function
# MORDECAI_FCM_WEBHOOK_SECRET=your-fcm-webhook-secret

# Optional: comma-separated origin allowlist for browser requests
# CORS_ALLOW_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# Optional: public URL for CORS/deep links when using Cloudflare Tunnel.
# Also used as the default "Mordecai URL for phone / WebView" in Commissions.
# MORDECAI_PUBLIC_URL=https://your-tunnel.trycloudflare.com

# Server port (default 3000)
PORT=3000

# Commission workspaces on disk (Cursor / local dev). Use an absolute path to put projects on D: etc.
# Default: <this repo>/commissions
# Windows example:
# COMMISSIONS_WORKSPACE=D:\MordecaiCommissions
# COMMISSIONS_WORKSPACE=./commissions

# Optional limits
# API_BODY_LIMIT=512kb
# API_RATE_LIMIT_PER_MIN=90
# POLL_RATE_LIMIT_PER_MIN=180
